generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  starter
  growth
  agency
}

enum UserRole {
  owner
  reviewer
  viewer
}

enum Platform {
  instagram
  facebook
  linkedin
  twitter
}

enum BrandVoice {
  professional
  friendly
  playful
  premium
}

enum AuditStatus {
  processing
  complete
  failed
}

enum CalendarStatus {
  generating
  active
  archived
}

enum PostStatus {
  draft
  pending_review
  approved
  published
  rejected
}

enum ContentType {
  image
  carousel
  reel
  story
}

model Tenant {
  id               String   @id @default(uuid()) @db.Uuid
  name             String   @db.VarChar(255)
  plan             Plan     @default(starter)
  stripeCustomerId String?  @map("stripe_customer_id") @db.VarChar(255)
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  users              User[]
  businessProfile    BusinessProfile?
  socialAccounts     SocialAccount[]
  auditReports       AuditReport[]
  competitorReports  CompetitorReport[]
  contentCalendars   ContentCalendar[]
  contentPosts       ContentPost[]

  @@map("tenants")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  email        String    @unique @db.VarChar(255)
  role         UserRole  @default(owner)
  passwordHash String?   @map("password_hash") @db.VarChar(255)
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("users")
}

model BusinessProfile {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @unique @map("tenant_id") @db.Uuid
  name            String      @db.VarChar(255)
  category        String?     @db.VarChar(100)
  location        Json?
  brandVoice      BrandVoice? @map("brand_voice")
  targetAudience  Json?       @map("target_audience")
  usps            String[]
  menuItems       Json?       @map("menu_items")
  upcomingEvents  Json?       @map("upcoming_events")
  competitorNames String[]    @map("competitor_names")
  updatedAt       DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("business_profiles")
}

model SocialAccount {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  platform        Platform
  platformUserId  String    @map("platform_user_id") @db.VarChar(255)
  accessToken     String?   @map("access_token")
  refreshToken    String?   @map("refresh_token")
  tokenExpiresAt  DateTime? @map("token_expires_at") @db.Timestamptz
  accountName     String?   @map("account_name") @db.VarChar(255)
  followersCount  Int?      @map("followers_count")
  isActive        Boolean   @default(true) @map("is_active")
  lastSyncedAt    DateTime? @map("last_synced_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, platform])
  @@map("social_accounts")
}

model AuditReport {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  generatedAt DateTime    @default(now()) @map("generated_at") @db.Timestamptz
  scores      Json?
  insights    Json?
  pdfUrl      String?     @map("pdf_url")
  status      AuditStatus @default(processing)
  periodStart DateTime?   @map("period_start") @db.Date
  periodEnd   DateTime?   @map("period_end") @db.Date

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, generatedAt(sort: Desc)])
  @@map("audit_reports")
}

model CompetitorReport {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  competitorName String   @map("competitor_name") @db.VarChar(255)
  platform       String?  @db.VarChar(50)
  metrics        Json?
  prosCons       Json?    @map("pros_cons")
  rawPosts       Json?    @map("raw_posts")
  generatedAt    DateTime @default(now()) @map("generated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("competitor_reports")
}

model ContentCalendar {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  monthStart      DateTime       @map("month_start") @db.Date
  strategySummary Json?          @map("strategy_summary")
  sheetsId        String?        @map("sheets_id") @db.VarChar(255)
  status          CalendarStatus @default(generating)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  posts  ContentPost[]

  @@map("content_calendars")
}

model ContentPost {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  calendarId     String       @map("calendar_id") @db.Uuid
  calendarDate   DateTime     @map("calendar_date") @db.Date
  platform       String       @db.VarChar(50)
  contentType    ContentType? @map("content_type")
  caption        String?
  hashtags       String[]
  imageUrl       String?      @map("image_url")
  imagePrompt    String?      @map("image_prompt")
  status         PostStatus   @default(draft)
  reviewerNotes  String?      @map("reviewer_notes")
  scheduledFor   DateTime?    @map("scheduled_for") @db.Timestamptz
  publishedAt    DateTime?    @map("published_at") @db.Timestamptz
  platformPostId String?      @map("platform_post_id") @db.VarChar(255)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  calendar  ContentCalendar @relation(fields: [calendarId], references: [id])
  analytics PostAnalytics[]

  @@index([tenantId, calendarDate])
  @@index([tenantId, status])
  @@index([scheduledFor])
  @@map("content_posts")
}

model PostAnalytics {
  id          String   @id @default(uuid()) @db.Uuid
  postId      String   @map("post_id") @db.Uuid
  impressions Int      @default(0)
  reach       Int      @default(0)
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  saves       Int      @default(0)
  clicks      Int      @default(0)
  recordedAt  DateTime @default(now()) @map("recorded_at") @db.Timestamptz

  post ContentPost @relation(fields: [postId], references: [id])

  @@index([postId, recordedAt(sort: Desc)])
  @@map("post_analytics")
}
