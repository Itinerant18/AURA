# ──────────────────────────────────────────
# AURA Environment Variables
# Copy this to .env and fill in real values
# ──────────────────────────────────────────

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/aura

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-jwt-secret-here
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google / Gemini AI
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Meta (Facebook / Instagram)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# LinkedIn
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Twitter/X
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# Image Generation
STABILITY_AI_API_KEY=your-stability-api-key
OPENAI_API_KEY=your-openai-api-key

# Stripe Billing
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=aura-assets

# Encryption
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# Service URLs (local dev)
AUTH_SERVICE_URL=http://localhost:4001
ONBOARDING_SERVICE_URL=http://localhost:4002
AUDIT_SERVICE_URL=http://localhost:4003
COMPETITOR_SERVICE_URL=http://localhost:4004
STRATEGY_SERVICE_URL=http://localhost:4005
CONTENT_SERVICE_URL=http://localhost:4006
REVIEW_SERVICE_URL=http://localhost:4007
PUBLISH_SERVICE_URL=http://localhost:4008
SHEETS_SERVICE_URL=http://localhost:4009
ANALYTICS_SERVICE_URL=http://localhost:4010
NOTIFICATION_SERVICE_URL=http://localhost:4011
BILLING_SERVICE_URL=http://localhost:4012
