# ═══════════════════════════════════════════════════════════════════════════════
# AURA — Environment Variables Reference
# ═══════════════════════════════════════════════════════════════════════════════
#
# This file documents EVERY environment variable any AURA service reads.
# Copy to `.env.local` for local dev or `.env` and fill in real values.
# NEVER commit `.env` or `.env.local`.
#
# Convention:
#   - <FILL_ME>           → you must provide a value before running
#   - <FROM_SECRET_MANAGER> → in prod, this is mounted from GCP Secret Manager
#   - sensible-default    → can be left as-is for local dev
#
# In prod, secrets come from Secret Manager (see .planning/07-secrets-and-config-strategy.md)
# and non-secret config comes from Terraform-injected env vars on Cloud Run.
# This file is the single source of truth for variable NAMES.
# ═══════════════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────────────
# 1. RUNTIME & ENVIRONMENT
# ───────────────────────────────────────────────────────────────────────────────

# Deployment env: local | staging | prod
NODE_ENV=local
ENV=local

# Logging level: error | warn | info | debug
LOG_LEVEL=debug

# GCP region (asia-south1 = Mumbai, MVP default per .planning/00-mvp-scope-and-cuts.md)
REGION=asia-south1

# GCP project ID (set per-environment)
GCP_PROJECT_ID=<FILL_ME>            # e.g. aura-staging or aura-prod

# OpenTelemetry service name (per service; overridden in Dockerfile/Cloud Run)
OTEL_SERVICE_NAME=auth-service
OTEL_EXPORTER_OTLP_ENDPOINT=         # leave empty for local; Cloud Trace exporter used in prod

# Sentry DSNs (one per service group)
SENTRY_DSN_WEB=<FILL_ME>
SENTRY_DSN_NODE=<FILL_ME>
SENTRY_DSN_PYTHON=<FILL_ME>
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=                       # git SHA, injected by CI


# ───────────────────────────────────────────────────────────────────────────────
# 2. DATABASE (PostgreSQL 16 / Cloud SQL)
# ───────────────────────────────────────────────────────────────────────────────

# Full connection string. Local uses Docker Compose Postgres; prod uses Cloud SQL private IP.
DATABASE_URL=postgresql://aura_app:password@localhost:5432/aura?schema=public

# Used by Prisma migrate to avoid pgbouncer/poolers
DIRECT_DATABASE_URL=postgresql://aura_app:password@localhost:5432/aura?schema=public

# DB password (in prod: from Secret Manager `db-app-password`)
DB_APP_PASSWORD=<FROM_SECRET_MANAGER>

# Pool sizing
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10


# ───────────────────────────────────────────────────────────────────────────────
# 3. REDIS / MEMORYSTORE
# ───────────────────────────────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379

# Prod uses TLS + auth; local does not
REDIS_AUTH_STRING=<FROM_SECRET_MANAGER>
REDIS_TLS_ENABLED=false


# ───────────────────────────────────────────────────────────────────────────────
# 4. PUB/SUB (Google Cloud)
# ───────────────────────────────────────────────────────────────────────────────

# Local emulator (set automatically by docker-compose). Empty in prod.
PUBSUB_EMULATOR_HOST=localhost:8085

# Pipeline topic paths — full resource names in prod
# Format: projects/<project>/topics/<topic-name>
PUBSUB_TOPIC_AUDIT_COMPLETED=projects/aura-local/topics/audit.completed
PUBSUB_TOPIC_COMPETITOR_REPORT_READY=projects/aura-local/topics/competitor.report.ready
PUBSUB_TOPIC_STRATEGY_GENERATED=projects/aura-local/topics/strategy.generated
PUBSUB_TOPIC_POST_READY=projects/aura-local/topics/post.ready
PUBSUB_TOPIC_POST_APPROVED=projects/aura-local/topics/post.approved
PUBSUB_TOPIC_POST_PUBLISHED=projects/aura-local/topics/post.published

# Internal topics (added by services as plan evolves)
PUBSUB_TOPIC_SOCIAL_CONNECTED=projects/aura-local/topics/social.connected
PUBSUB_TOPIC_ONBOARDING_COMPLETED=projects/aura-local/topics/onboarding.completed
PUBSUB_TOPIC_PUBLISH_FAILED=projects/aura-local/topics/publish.failed
PUBSUB_TOPIC_SUBSCRIPTION_CREATED=projects/aura-local/topics/subscription.created
PUBSUB_TOPIC_SUBSCRIPTION_CANCELED=projects/aura-local/topics/subscription.canceled
PUBSUB_TOPIC_SUBSCRIPTION_PAYMENT_FAILED=projects/aura-local/topics/subscription.payment_failed
PUBSUB_TOPIC_SUBSCRIPTION_PAYMENT_SUCCEEDED=projects/aura-local/topics/subscription.payment_succeeded

# Operational topics
PUBSUB_TOPIC_DEADLETTER=projects/aura-local/topics/aura.deadletter
PUBSUB_TOPIC_AUDIT_LOG=projects/aura-local/topics/aura.audit-log

# Subscription names (for services that consume) — push endpoints set in Terraform, not here
PUBSUB_SUB_STRATEGY_AUDIT=audit-completed--strategy
PUBSUB_SUB_STRATEGY_COMPETITOR=competitor-ready--strategy
PUBSUB_SUB_CONTENT_STRATEGY=strategy-generated--content
PUBSUB_SUB_SHEETS_STRATEGY=strategy-generated--sheets
PUBSUB_SUB_REVIEW_POST_READY=post-ready--review
PUBSUB_SUB_PUBLISH_POST_APPROVED=post-approved--publish
PUBSUB_SUB_ANALYTICS_POST_PUBLISHED=post-published--analytics
PUBSUB_SUB_SHEETS_POST_PUBLISHED=post-published--sheets
PUBSUB_SUB_NOTIFY_AUDIT=audit-completed--notification
PUBSUB_SUB_NOTIFY_COMPETITOR=competitor-ready--notification
PUBSUB_SUB_NOTIFY_STRATEGY=strategy-generated--notification
PUBSUB_SUB_NOTIFY_POST_READY=post-ready--notification
PUBSUB_SUB_NOTIFY_POST_PUBLISHED=post-published--notification


# ───────────────────────────────────────────────────────────────────────────────
# 5. CLOUD STORAGE (GCS) — buckets per .planning/02-gcp-bootstrap.md Step 10
# ───────────────────────────────────────────────────────────────────────────────

GCS_BUCKET_PUBLIC=aura-public-local      # public CDN for post images
GCS_BUCKET_PRIVATE=aura-private-local    # private — audit PDFs, scraping snapshots
GCS_BUCKET_UPLOADS=aura-uploads-local    # temporary user uploads (7-day TTL)

# Signed URL default expiry (seconds)
GCS_SIGNED_URL_TTL=604800                 # 7 days


# ───────────────────────────────────────────────────────────────────────────────
# 6. CLOUD TASKS (used by content-service + analytics-service)
# ───────────────────────────────────────────────────────────────────────────────

CLOUD_TASKS_LOCATION=asia-south1
CLOUD_TASKS_QUEUE_CONTENT_GENERATION=projects/aura-local/locations/asia-south1/queues/content-generation-queue
CLOUD_TASKS_QUEUE_ANALYTICS_POLL=projects/aura-local/locations/asia-south1/queues/analytics-poll-queue

# Service account email used to sign OIDC tokens for Cloud Tasks → Cloud Run invocations
CLOUD_TASKS_INVOKER_SA=<FILL_ME>          # e.g. sa-content-svc@aura-staging.iam.gserviceaccount.com


# ───────────────────────────────────────────────────────────────────────────────
# 7. CLOUD SCHEDULER (cron triggers — values set in Terraform, mirrored here for ref)
# ───────────────────────────────────────────────────────────────────────────────

# These are reference-only; Cloud Scheduler hits service endpoints directly.
# Local dev cron simulator (e.g. node-cron) reads these.
CRON_AUDIT_MONTHLY=0 2 1 * *              # 1st of month, 02:00 IST
CRON_DIGEST_MORNING=0 9 * * *             # 09:00 IST daily
CRON_DIGEST_EVENING=0 18 * * *            # 18:00 IST daily
CRON_OUTBOX_RELAY=*/30 * * * * *          # every 30s (6-field cron)
CRON_PUBLISH_SWEEP=*/5 * * * *            # every 5 min
CRON_TOKEN_EXPIRY_CHECK=0 2 * * *         # 02:00 IST daily


# ───────────────────────────────────────────────────────────────────────────────
# 8. AUTHENTICATION & JWT
# ───────────────────────────────────────────────────────────────────────────────

# Frontend origin (CORS, cookie domain, email links)
FRONTEND_ORIGIN=http://localhost:3000

# OAuth callback base URL (where social platforms redirect back to)
OAUTH_CALLBACK_BASE=http://localhost:4001  # auth-service in local dev

# JWT signing — RS256 keypair, PEM format
# In prod: mounted from Secret Manager
JWT_PRIVATE_KEY=<FROM_SECRET_MANAGER>
JWT_PUBLIC_KEY=<FROM_SECRET_MANAGER>
JWT_ISSUER=aura-auth
JWT_AUDIENCE=aura-services
JWT_ACCESS_TTL=900                         # 15 min in seconds
JWT_REFRESH_TTL=2592000                    # 30 days

# JWKS endpoint (served by auth-service; cached by other services)
JWKS_URI=http://localhost:4001/.well-known/jwks.json
JWKS_CACHE_TTL=3600                        # 1 hour

# NextAuth.js (apps/web)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<FILL_ME>                  # generate: openssl rand -hex 32

# Auth-service rate limiting (Redis-backed)
RATE_LIMIT_LOGIN_PER_IP=5                  # per 15 min
RATE_LIMIT_LOGIN_PER_ACCOUNT=5
RATE_LIMIT_SIGNUP_PER_IP=3                 # per hour
RATE_LIMIT_PASSWORD_RESET_PER_EMAIL=3      # per hour
RATE_LIMIT_DEFAULT_RPM=100


# ───────────────────────────────────────────────────────────────────────────────
# 9. ENCRYPTION (AES-256-GCM for OAuth tokens at rest)
# ───────────────────────────────────────────────────────────────────────────────

# 32 random bytes, base64-encoded. Generate locally with:
#   openssl rand -base64 32
DB_ENCRYPTION_KEY=<FROM_SECRET_MANAGER>

# Multi-version support for key rotation (Phase 1.5).
# Format: v1=<key>,v2=<key>. The highest version is used for new writes.
DB_ENCRYPTION_KEY_V1=<FROM_SECRET_MANAGER>
DB_ENCRYPTION_KEY_V2=                      # filled in only during rotation


# ───────────────────────────────────────────────────────────────────────────────
# 10. AI / LLM PROVIDERS
# ───────────────────────────────────────────────────────────────────────────────

# Google Gemini — two keys, one per model
GEMINI_FLASH_API_KEY=<FROM_SECRET_MANAGER> # gemini-1.5-flash (audit, captions, hashtags)
GEMINI_PRO_API_KEY=<FROM_SECRET_MANAGER>   # gemini-1.5-pro (strategy, competitor)
GEMINI_FLASH_MODEL=gemini-1.5-flash
GEMINI_PRO_MODEL=gemini-1.5-pro
GEMINI_REQUEST_TIMEOUT_MS=60000

# Stability AI (image generation, Starter+ tiers)
STABILITY_API_KEY=<FROM_SECRET_MANAGER>
STABILITY_CORE_ENDPOINT=https://api.stability.ai/v2beta/stable-image/generate/core
STABILITY_ULTRA_ENDPOINT=https://api.stability.ai/v2beta/stable-image/generate/ultra

# OpenAI DALL-E 3 (Growth+/Agency tier image gen)
OPENAI_API_KEY=<FROM_SECRET_MANAGER>
OPENAI_DALLE_MODEL=dall-e-3

# Image gen cost caps (per tenant per month — enforced in content-service)
IMAGE_QUOTA_STARTER=20
IMAGE_QUOTA_GROWTH=60
IMAGE_QUOTA_AGENCY=100


# ───────────────────────────────────────────────────────────────────────────────
# 11. META — INSTAGRAM + FACEBOOK
# ───────────────────────────────────────────────────────────────────────────────

META_APP_ID=<FILL_ME>
META_APP_SECRET=<FROM_SECRET_MANAGER>
META_GRAPH_API_VERSION=v20.0
META_GRAPH_API_BASE=https://graph.facebook.com/v20.0
META_OAUTH_REDIRECT_URI=http://localhost:4001/oauth/meta/callback

# App review state — used to gate certain features in pre-approved environments
META_APP_MODE=development                  # development | live

# Webhook (incoming events from Meta — Phase 1.5)
META_WEBHOOK_VERIFY_TOKEN=<FILL_ME>


# ───────────────────────────────────────────────────────────────────────────────
# 12. LINKEDIN (read-only in MVP)
# ───────────────────────────────────────────────────────────────────────────────

LINKEDIN_CLIENT_ID=<FILL_ME>
LINKEDIN_CLIENT_SECRET=<FROM_SECRET_MANAGER>
LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:4001/oauth/linkedin/callback
LINKEDIN_API_VERSION=202405


# ───────────────────────────────────────────────────────────────────────────────
# 13. TWITTER / X (read-only in MVP)
# ───────────────────────────────────────────────────────────────────────────────

TWITTER_CLIENT_ID=<FILL_ME>
TWITTER_CLIENT_SECRET=<FROM_SECRET_MANAGER>
TWITTER_BEARER_TOKEN=<FROM_SECRET_MANAGER>
TWITTER_OAUTH_REDIRECT_URI=http://localhost:4001/oauth/twitter/callback


# ───────────────────────────────────────────────────────────────────────────────
# 14. GOOGLE — OAuth (for Sheets + GBP) + Places API
# ───────────────────────────────────────────────────────────────────────────────

GOOGLE_OAUTH_CLIENT_ID=<FILL_ME>
GOOGLE_OAUTH_CLIENT_SECRET=<FROM_SECRET_MANAGER>
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4001/oauth/google/callback

# Combined Sheets + GBP scopes (single consent screen — see auth-service spec)
GOOGLE_OAUTH_SCOPES=openid,email,profile,https://www.googleapis.com/auth/spreadsheets,https://www.googleapis.com/auth/drive.file,https://www.googleapis.com/auth/business.manage

# Places API (server-side key, no OAuth needed)
PLACES_API_KEY=<FROM_SECRET_MANAGER>

# Application Default Credentials path (local only — for gcloud-auth SDKs)
GOOGLE_APPLICATION_CREDENTIALS=         # leave empty; uses `gcloud auth application-default login`


# ───────────────────────────────────────────────────────────────────────────────
# 15. STRIPE (billing-service)
# ───────────────────────────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=<FROM_SECRET_MANAGER>    # sk_test_... locally, sk_live_... in prod
STRIPE_PUBLISHABLE_KEY=<FILL_ME>           # pk_test_... — used by apps/web frontend
STRIPE_WEBHOOK_SECRET=<FROM_SECRET_MANAGER>
STRIPE_API_VERSION=2024-12-18.acacia

# Stripe Product / Price IDs — fill after creating them in Stripe dashboard
STRIPE_PRICE_STARTER=<FILL_ME>             # price_...
STRIPE_PRICE_GROWTH=<FILL_ME>
STRIPE_PRICE_AGENCY=<FILL_ME>

# Checkout return URLs
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/settings/billing?status=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/settings/billing?status=cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/settings/billing

# Grace period (days) after failed payment before subscription is canceled
STRIPE_GRACE_PERIOD_DAYS=7


# ───────────────────────────────────────────────────────────────────────────────
# 16. EMAIL (Resend — notification-service)
# ───────────────────────────────────────────────────────────────────────────────

# Provider toggle: resend | sendgrid | ses
EMAIL_PROVIDER=resend

RESEND_API_KEY=<FROM_SECRET_MANAGER>
SENDGRID_API_KEY=                          # optional fallback
AWS_SES_REGION=                            # optional fallback

FROM_EMAIL=hello@aura.app
FROM_NAME=AURA
REPLY_TO_EMAIL=support@aura.app
SUPPORT_EMAIL=support@aura.app
SECURITY_EMAIL=security@aura.app

# Webhook for bounces/complaints
EMAIL_WEBHOOK_SECRET=<FROM_SECRET_MANAGER>


# ───────────────────────────────────────────────────────────────────────────────
# 17. POSTING / SCHEDULING DEFAULTS
# ───────────────────────────────────────────────────────────────────────────────

# Default tenant timezone (overridable per tenant in settings)
DEFAULT_TENANT_TIMEZONE=Asia/Kolkata

# Optimal posting times per platform — JSON, used by review-service when computing scheduled_for
# Format: { "instagram": ["09:00","13:00","19:00"], "facebook": [...] }
OPTIMAL_POST_TIMES_IST={"instagram":["09:00","13:00","19:00","21:00"],"facebook":["10:00","15:00","20:00"],"linkedin":["08:00","12:00","17:00"],"twitter":["09:00","12:00","18:00","21:00"]}

# Publish retry policy
PUBLISH_MAX_RETRIES=3
PUBLISH_RETRY_BACKOFF_MS=1000


# ───────────────────────────────────────────────────────────────────────────────
# 18. INTERNAL SERVICE URLS (local dev)
# In Cloud Run, services discover each other via private DNS:
#   https://<service>-<hash>-as.a.run.app
# ───────────────────────────────────────────────────────────────────────────────

API_GATEWAY_URL=http://localhost:4000

AUTH_SERVICE_URL=http://localhost:4001
ONBOARDING_SERVICE_URL=http://localhost:4002
AUDIT_SERVICE_URL=http://localhost:4003
COMPETITOR_SERVICE_URL=http://localhost:4004
STRATEGY_SERVICE_URL=http://localhost:4005
CONTENT_SERVICE_URL=http://localhost:4006
REVIEW_SERVICE_URL=http://localhost:4007
PUBLISH_SERVICE_URL=http://localhost:4008
SHEETS_SERVICE_URL=http://localhost:4009
ANALYTICS_SERVICE_URL=http://localhost:4010
NOTIFICATION_SERVICE_URL=http://localhost:4011
BILLING_SERVICE_URL=http://localhost:4012

# Service-to-service auth: in prod, uses GCP service-account OIDC tokens.
# In local dev, this static shared secret short-circuits OIDC verification.
INTERNAL_SERVICE_AUTH_TOKEN=<FILL_ME>      # generate: openssl rand -hex 32


# ───────────────────────────────────────────────────────────────────────────────
# 19. NEXT.JS (apps/web) — public env vars (NEXT_PUBLIC_* leaked to browser)
# ───────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<FILL_ME>
NEXT_PUBLIC_SENTRY_DSN=<FILL_ME>
NEXT_PUBLIC_POSTHOG_KEY=                   # optional product analytics
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_ENV=local


# ───────────────────────────────────────────────────────────────────────────────
# 20. FEATURE FLAGS (env-var driven for MVP — no SaaS flag service)
# ───────────────────────────────────────────────────────────────────────────────

FEATURE_AGENCY_TIER_ENABLED=true
FEATURE_LINKEDIN_PUBLISH_ENABLED=false     # MVP: read-only
FEATURE_TWITTER_PUBLISH_ENABLED=false      # MVP: read-only
FEATURE_DALLE_FOR_GROWTH=false             # if false, Stability Ultra is used
FEATURE_BIGQUERY_ANALYTICS=false           # MVP reads from Postgres; Phase 1.5 BigQuery
FEATURE_PUSH_NOTIFICATIONS=false           # MVP: email + in-app only
FEATURE_WHATSAPP_NOTIFICATIONS=false       # Phase 2


# ───────────────────────────────────────────────────────────────────────────────
# 21. OBSERVABILITY / MONITORING
# ───────────────────────────────────────────────────────────────────────────────

# Slack webhook for deploy + alert notifications
SLACK_WEBHOOK_DEPLOY_NOTIFY=<FILL_ME>
SLACK_WEBHOOK_ALERTS=<FILL_ME>
SLACK_WEBHOOK_INFRA_CHANGES=<FILL_ME>

# Cloud Logging sampling
LOG_SAMPLE_RATE_INFO=1.0                    # 100% of info logs in MVP; reduce later
LOG_SAMPLE_RATE_DEBUG=0.1


# ───────────────────────────────────────────────────────────────────────────────
# 22. SECURITY HEADERS / CSP
# ───────────────────────────────────────────────────────────────────────────────

CSP_REPORT_URI=https://aura.report-uri.com/r/d/csp/enforce
HSTS_MAX_AGE=31536000
ALLOWED_CORS_ORIGINS=http://localhost:3000,https://app.aura.app,https://staging.aura.app


# ───────────────────────────────────────────────────────────────────────────────
# 23. DEVELOPMENT / TESTING ONLY
# (Not used in prod; safe defaults for local + CI)
# ───────────────────────────────────────────────────────────────────────────────

# Disable email sending in tests; logs to console instead
TEST_DISABLE_EMAIL=false

# Seed-data flags
SEED_INCLUDE_DEMO_TENANTS=true
SEED_TENANT_COUNT=3

# Playwright base URL for E2E
PLAYWRIGHT_BASE_URL=http://localhost:3000

# CI flag
CI=false


# ═══════════════════════════════════════════════════════════════════════════════
# END — for the secret-source matrix of which service can access which secret,
# see .planning/07-secrets-and-config-strategy.md
# ═══════════════════════════════════════════════════════════════════════════════
